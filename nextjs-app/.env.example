# AL Hukuk AI — Next.js Environment Variables Template
# Copy this file to .env.local and add your actual API keys.

# Google Gemini API Key (MANDATORY for AI Legal Search, Petition Studio, Chat Assistant, Case Simulator)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth Secret (Required if you decide to integrate real multi-tenant auth in the future)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
