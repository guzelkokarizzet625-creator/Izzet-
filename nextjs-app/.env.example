# AL Hukuk AI — Next.js Environment Variables Template
# Copy this file to .env.local and add your actual API keys.

# Google Gemini API Key (MANDATORY for AI Legal Search, Petition Studio, Chat Assistant, Case Simulator)
# Get your API key from Google AI Studio: https://aistudio.google.com/
# On Vercel, define this environment variable under the name: GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional, used for premium dual-model orchestration & parallel verification)
# On Vercel, define this environment variable under the name: OPENAI_API_KEY
OPENAI_API_KEY=your_openai_api_key_here

# NextAuth Secret (Required if you decide to integrate real multi-tenant auth in the future)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Firebase Configuration (Optional, fallback defaults are provided automatically)
# Add your Firebase Web App credentials below if you want to use your own production Firestore database.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

